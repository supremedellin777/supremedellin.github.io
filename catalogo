<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<title>Supreme Medellín Catálogo</title>

<style>

body{
font-family: Arial;
background:#f5f5f5;
margin:0;
}

header{
background:black;
color:white;
padding:20px;
text-align:center;
font-size:28px;
letter-spacing:2px;
}

.catalogo{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:30px;
}

.producto{
background:white;
border-radius:10px;
overflow:hidden;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
text-align:center;
}

.producto img{
width:100%;
}

.producto h3{
margin:10px 0;
}

.precio{
color:#e60023;
font-size:18px;
font-weight:bold;
}

.boton{
display:inline-block;
margin:15px;
padding:10px 20px;
background:black;
color:white;
text-decoration:none;
border-radius:5px;
}

</style>
</head>

<body>

<header>
SUPREME MEDELLÍN
</header>

<section class="catalogo">

<div class="producto">
<img src="foto1.jpg">
<h3>Nike x Supreme</h3>
<p class="precio">$850.000</p>
<a class="boton" href="https://wa.me/573000000000">Comprar</a>
</div>

<div class="producto">
<img src="foto2.jpg">
<h3>Supreme Hoodie</h3>
<p class="precio">$600.000</p>
<a class="boton" href="https://wa.me/573000000000">Comprar</a>
</div>

<div class="producto">
<img src="foto3.jpg">
<h3>Supreme Tee</h3>
<p class="precio">$350.000</p>
<a class="boton" href="https://wa.me/573000000000">Comprar</a>
</div>

</section>

</body>
</html>
